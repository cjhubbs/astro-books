---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const books = await getCollection("books");

// Sort by most recent date_read (newest first), handling missing dates
books.sort((a, b) => {
  const dateA = a.data.book.date_read?.at(-1) ? new Date(a.data.book.date_read.at(-1)).getTime() : 0;
  const dateB = b.data.book.date_read?.at(-1) ? new Date(b.data.book.date_read.at(-1)).getTime() : 0;
  return dateB - dateA; // descending: newest first
});
---

<BaseLayout>
  <h1>All Books</h1>

  <ul>
    {books.map((book) => (
      <li>
        <a href={`/books/${book.id.replace('.md', '')}`}>
          {book.data.book.title}
        </a>
        — {book.data.book.author} ({book.data.book.date_read?.[0]?.toDateString()})
      </li>
    ))}
  </ul>
</BaseLayout>