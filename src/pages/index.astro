---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

// Get all books
const allBooks = await getCollection("books");

// Sort by most recent date_read (newest first), handling missing dates
allBooks.sort((a, b) => {
  const dateA = a.data.book.date_read?.at(-1) ? new Date(a.data.book.date_read.at(-1)).getTime() : 0;
  const dateB = b.data.book.date_read?.at(-1) ? new Date(b.data.book.date_read.at(-1)).getTime() : 0;
  return dateB - dateA; // descending: newest first
});

// Pagination
const BOOKS_PER_PAGE = 12; // 4 columns × 3 rows
const currentPage = 1;
const totalPages = Math.ceil(allBooks.length / BOOKS_PER_PAGE);
const startIndex = (currentPage - 1) * BOOKS_PER_PAGE;
const books = allBooks.slice(startIndex, startIndex + BOOKS_PER_PAGE);

// Helper function to render star rating
function renderStars(rating: number | undefined): string {
  if (!rating) return '';
  const fullStars = Math.floor(rating);
  const emptyStars = 5 - fullStars;
  const filledStars = '★'.repeat(fullStars);
  const emptyStarDisplay = '☆'.repeat(emptyStars);
  return filledStars + emptyStarDisplay;
}

// Helper function to get latest date read
function getLatestDateRead(dateRead: Date[] | undefined): string {
  if (!dateRead || dateRead.length === 0) return '';
  const latestDate = dateRead[dateRead.length - 1];
  return latestDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

// Helper function to generate page links
function generatePageLinks(current: number, total: number): { page: number; isActive: boolean }[] {
  const links = [];
  const showMax = 5;
  let start = Math.max(1, current - Math.floor(showMax / 2));
  let end = Math.min(total, start + showMax - 1);
  
  if (end - start + 1 < showMax) {
    start = Math.max(1, end - showMax + 1);
  }
  
  for (let i = start; i <= end; i++) {
    links.push({ page: i, isActive: i === current });
  }
  
  return links;
}

const pageLinks = generatePageLinks(currentPage, totalPages);
---

<BaseLayout>
  <div class="intro">
    <div class="flex-container">
    <h2>Hi, I'm Chris. Welcome to my Booklog.</h2>
    <p>I love books.</p> 
    <p>I was going to say I love reading books, but I own far too many that I haven't yet read, so maybe the first statement is more accurate. </p>
    <p>I’ve been keeping track of my reading through various means since 2007. At various times I've used my blog, Goodreads, iOS apps, and at least one other static site, and never been 100% happy with any of them. This is my favorite one yet, though!</p>
    <p>Scroll down to see the most recent books I've read, or use the links above to explore by year or by author. I'd love to hear about your favorite books!</p>
    </div>
    <div class="headshot">
      <img src="/img/chris.jpg" alt="Chris" />
    </div>
  </div>
  <div class="book-grid">
    {books.map((book) => {
      const bookSlug = book.id.replace('.md', '');
      const localImagePath = `/img/${bookSlug}.jpg`;
      return (
        <a href={`/books/${bookSlug}`} class="book-card">
          {localImagePath || book.data.book.cover_image_url ? (
            <img 
              src={localImagePath}
              onerror={`this.onerror=null; this.src='${book.data.book.cover_image_url || ''}'`}
              alt={`${book.data.book.title} by ${book.data.book.author}`}
              class="book-cover"
            />
          ) : (
            <div class="book-cover-placeholder">No Cover Available</div>
          )}
          <div class="book-info">
            <h3 class="book-title">{book.data.book.title}</h3>
            <p class="book-author">{book.data.book.author}</p>
            {book.data.book.rating && (
              <div class="book-rating">
                <span class="stars">
                  {renderStars(book.data.book.rating)}
                </span>
              </div>
            )}
            {book.data.book.date_read && book.data.book.date_read.length > 0 && (
              <p class="book-date">{getLatestDateRead(book.data.book.date_read)}</p>
            )}
          </div>
        </a>
      );
    })}
  </div>

  {totalPages > 1 && (
    <div class="pagination">
      <a 
        href="/"
        class="pagination-button"
        style="opacity: 0.5; cursor: not-allowed; pointer-events: none;"
      >
        ← Previous
      </a>
      
      {pageLinks.map(({ page, isActive }) => (
        <a 
          href={page === 1 ? '/' : `/page/${page}`}
          class="pagination-button"
          style={isActive ? 'background-color: var(--accent-color); color: white;' : ''}
        >
          {page}
        </a>
      ))}
      
      {pageLinks[pageLinks.length - 1]?.page < totalPages && (
        <>
          {pageLinks[pageLinks.length - 1]?.page < totalPages - 1 && <span class="pagination-info">...</span>}
          <a href={`/page/${totalPages}`} class="pagination-button">{totalPages}</a>
        </>
      )}
      
      <a href="/page/2" class="pagination-button">
        Next →
      </a>
      
      <span class="pagination-info">
        Page {currentPage} of {totalPages}
      </span>
    </div>
  )}
</BaseLayout>

<style>
  .book-card {
    text-decoration: none;
    color: inherit;
  }
</style>
