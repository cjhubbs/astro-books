---
import { getCollection } from "astro:content";
import BaseLayout from "../../../../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const books = await getCollection("books");
  const yearsSet = new Set<number>();
  
  // Extract all unique years from date_read entries
  books.forEach(book => {
    if (book.data.book.date_read && book.data.book.date_read.length > 0) {
      book.data.book.date_read.forEach(date => {
        yearsSet.add(date.getFullYear());
      });
    }
  });
  
  const years = Array.from(yearsSet).sort();
  
  return years.flatMap((year) => {
    // Collect all books read in the given year
    interface ReadEntry {
      book: any;
      date: Date;
    }

    const readsInYear: ReadEntry[] = [];

    books.forEach(book => {
      if (book.data.book.date_read && book.data.book.date_read.length > 0) {
        book.data.book.date_read.forEach(date => {
          if (date.getFullYear() === year) {
            readsInYear.push({
              book,
              date
            });
          }
        });
      }
    });

    const BOOKS_PER_PAGE = 12;
    const totalBooks = readsInYear.length;
    const totalPages = Math.ceil(totalBooks / BOOKS_PER_PAGE);

    return Array.from({ length: totalPages }, (_, i) => ({
      params: { year: year.toString(), page: String(i + 1) },
      props: { year, page: i + 1, allReads: readsInYear, totalPages },
    }));
  });
}

interface Props {
  year: number;
  page: number;
  allReads: any[];
  totalPages: number;
}

const { year, page, allReads, totalPages } = Astro.props;
const BOOKS_PER_PAGE = 12;
const startIndex = (page - 1) * BOOKS_PER_PAGE;
const paginatedBooks = allReads.slice(startIndex, startIndex + BOOKS_PER_PAGE);

const totalBooks = allReads.length;
const totalPages_calc = totalPages;

// Calculate total pages
const totalPagesCount = allReads.reduce((sum, entry) => {
  const pages = entry.book.data.book.pages || 0;
  return sum + pages;
}, 0);

// Helper function to render star rating
function renderStars(rating: number | undefined): string {
  if (!rating) return '';
  const fullStars = Math.floor(rating);
  const emptyStars = 5 - fullStars;
  const filledStars = '★'.repeat(fullStars);
  const emptyStarDisplay = '☆'.repeat(emptyStars);
  return filledStars + emptyStarDisplay;
}

// Helper function to get latest date read
function getLatestDateRead(dateRead: Date[] | undefined): string {
  if (!dateRead || dateRead.length === 0) return '';
  const latestDate = dateRead[dateRead.length - 1];
  return latestDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

// Helper function to generate page links
function generatePageLinks(current: number, total: number): { page: number; isActive: boolean }[] {
  const links = [];
  const showMax = 5;
  let start = Math.max(1, current - Math.floor(showMax / 2));
  let end = Math.min(total, start + showMax - 1);
  
  if (end - start + 1 < showMax) {
    start = Math.max(1, end - showMax + 1);
  }
  
  for (let i = start; i <= end; i++) {
    links.push({ page: i, isActive: i === current });
  }
  
  return links;
}

const pageLinks = generatePageLinks(page, totalPages_calc);
---

<BaseLayout>
  <h2 style="text-align: center; margin-bottom: 1rem;">Books Read in {year}</h2>
  
  <div style="text-align: center; margin-bottom: 2rem; color: var(--text-secondary);">
    <p>
      <strong style="color: var(--text-primary);">{totalBooks}</strong> book{totalBooks !== 1 ? 's' : ''} read • 
      <strong style="color: var(--text-primary);">{totalPagesCount}</strong> page{totalPagesCount !== 1 ? 's' : ''}
    </p>
  </div>

  {totalBooks === 0 ? (
    <p style="text-align: center;">No books read in {year}.</p>
  ) : (
    <>
      <div class="book-grid">
        {paginatedBooks.map((entry) => {
          const bookSlug = entry.book.id.replace('.md', '');
          const localImagePath = `/img/${bookSlug}.jpg`;
          return (
            <a href={`/books/${bookSlug}`} class="book-card">
              {localImagePath || entry.book.data.book.cover_image_url ? (
                <img 
                  src={localImagePath}
                  onerror={`this.onerror=null; this.src='${entry.book.data.book.cover_image_url || ''}'`}
                  alt={`${entry.book.data.book.title} by ${entry.book.data.book.author}`}
                  class="book-cover"
                />
              ) : (
                <div class="book-cover-placeholder">No Cover Available</div>
              )}
              <div class="book-info">
                <h3 class="book-title">{entry.book.data.book.title}</h3>
                <p class="book-author">{entry.book.data.book.author}</p>
                {entry.book.data.book.rating && (
                  <div class="book-rating">
                    <span class="stars">
                      {renderStars(entry.book.data.book.rating)}
                    </span>
                  </div>
                )}
                {entry.book.data.book.date_read && entry.book.data.book.date_read.length > 0 && (
                  <p class="book-date">{getLatestDateRead(entry.book.data.book.date_read)}</p>
                )}
              </div>
            </a>
          );
        })}
      </div>

      {totalPages_calc > 1 && (
        <div class="pagination">
          <a 
            href={page === 2 ? `/books/by-year/${year}` : `/books/by-year/${year}/page/${page - 1}`}
            class="pagination-button"
            style={page === 1 ? 'opacity: 0.5; cursor: not-allowed; pointer-events: none;' : ''}
          >
            ← Previous
          </a>
          
          {pageLinks.map(({ page: pageNum, isActive }) => (
            <a 
              href={pageNum === 1 ? `/books/by-year/${year}` : `/books/by-year/${year}/page/${pageNum}`}
              class="pagination-button"
              style={isActive ? 'background-color: var(--accent-color); color: white;' : ''}
            >
              {pageNum}
            </a>
          ))}
          
          {pageLinks[pageLinks.length - 1]?.page < totalPages_calc && (
            <>
              {pageLinks[pageLinks.length - 1]?.page < totalPages_calc - 1 && <span class="pagination-info">...</span>}
              <a href={`/books/by-year/${year}/page/${totalPages_calc}`} class="pagination-button">{totalPages_calc}</a>
            </>
          )}
          
          <a 
            href={`/books/by-year/${year}/page/${page + 1}`}
            class="pagination-button"
            style={page === totalPages_calc ? 'opacity: 0.5; cursor: not-allowed; pointer-events: none;' : ''}
          >
            Next →
          </a>
          
          <span class="pagination-info">
            Page {page} of {totalPages_calc}
          </span>
        </div>
      )}
    </>
  )}
</BaseLayout>

<style>
  .book-card {
    text-decoration: none;
    color: inherit;
  }
</style>
