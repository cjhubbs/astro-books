---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";

const books = await getCollection("books");
const yearsSet = new Set<number>();

// Extract all unique years from date_read entries
books.forEach(book => {
  if (book.data.book.date_read && book.data.book.date_read.length > 0) {
    book.data.book.date_read.forEach(date => {
      yearsSet.add(date.getFullYear());
    });
  }
});

// Sort years in descending order (most recent first)
const years = Array.from(yearsSet).sort((a, b) => b - a);

// Calculate stats for each year
const yearStats = years.map(year => {
  let bookCount = 0;
  let pageCount = 0;
  
  books.forEach(book => {
    if (book.data.book.date_read && book.data.book.date_read.length > 0) {
      book.data.book.date_read.forEach(date => {
        if (date.getFullYear() === year) {
          bookCount++;
          pageCount += book.data.book.pages || 0;
        }
      });
    }
  });
  
  return { year, bookCount, pageCount };
});
---

<BaseLayout>
  <h2 style="margin-bottom: 2rem; text-align: center;">Reading by Year</h2>
  
  {years.length === 0 ? (
    <p>No reading data available.</p>
  ) : (
    <div class="year-grid">
      {yearStats.map(stat => (
        <a href={`/books/by-year/${stat.year}`} class="year-card">
          <div class="year-number">{stat.year}</div>
          <div class="year-stats">
            <div class="stat-item">
              <span class="stat-value">{stat.bookCount}</span>
              <span class="stat-label">book{stat.bookCount !== 1 ? 's' : ''}</span>
            </div>
            <div class="stat-item">
              <span class="stat-value">{stat.pageCount}</span>
              <span class="stat-label">page{stat.pageCount !== 1 ? 's' : ''}</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  )}
</BaseLayout>

<style>
  .year-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .year-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    background-color: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 0.5rem;
    text-decoration: none;
    color: inherit;
    transition: all 0.3s ease;
    box-shadow: var(--shadow);
    min-height: 200px;
  }

  .year-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-hover);
  }

  .year-number {
    font-size: 3rem;
    font-weight: bold;
    color: var(--accent-color);
    margin-bottom: 1rem;
  }

  .year-stats {
    display: flex;
    gap: 2rem;
    width: 100%;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex: 1;
  }

  .stat-value {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  .stat-label {
    font-size: 0.75rem;
    color: var(--text-secondary);
    margin-top: 0.25rem;
  }
</style>
